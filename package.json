{
  "name": "blog-taast",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "seed:competitions": "npx tsx scripts/seed-competitions.ts",
    "seed:teams": "npx tsx scripts/seed-teams.ts",
    "seed:matches": "npx tsx scripts/seed-matches.ts",
    "seed:all": "npx tsx scripts/seed-competitions.ts && npx tsx scripts/seed-teams.ts && npx tsx scripts/seed-matches.ts",
    "generate": "npx tsx scripts/generate-articles.ts",
    "generate:teams": "npx tsx scripts/generate-articles.ts teams",
    "generate:matches": "npx tsx scripts/generate-articles.ts matches",
    "generate:h2h": "npx tsx scripts/generate-articles.ts h2h"
  },
  "dependencies": {
    "@prisma/client": "^7.5.0",
